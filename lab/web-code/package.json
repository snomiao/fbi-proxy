{
  "name": "web-code",
  "private": true,
  "type": "module",
  "description": "fbi-proxy lab: VS Code web + iframe shell under one origin",
  "scripts": {
    "dev": "bun run start.ts",
    "shell": "vite --port 3001 --strictPort",
    "daemon": "bun run daemon.ts",
    "daemon:stop": "bun run daemon.ts --uninstall",
    "daemon:logs": "oxmgr logs web-code-lab",
    "daemon:status": "oxmgr status web-code-lab"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.6",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^18",
    "react-dom": "^18",
    "ws": "^8.21.0"
  }
}
